# --- Web portal .env.production ---
# Web is server-rendered; it proxies /api/* to the API origin via next.config.js
# rewrites. Set this to the public API URL (with https).
NEXT_PUBLIC_API_BASE=/api
API_INTERNAL_URL=http://127.0.0.1:4817

# If your next.config.js uses NEXT_PUBLIC_API_BASE_URL, set it here too:
NEXT_PUBLIC_API_BASE_URL=https://API_DOMAIN/api
