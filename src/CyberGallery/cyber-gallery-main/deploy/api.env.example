# --- API .env (Postgres on host loopback) ---
NODE_ENV=production
PORT=4817
DATABASE_URL=postgresql://cg:CHANGE_ME@127.0.0.1:5432/cyber_gallery?schema=public
REDIS_URL=redis://127.0.0.1:6379

# 64+ random hex chars each. Generate via: openssl rand -hex 48
JWT_ACCESS_SECRET=CHANGE_ME_LONG_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM_DIFFERENT

# Comma-separated list of allowed origins (the web portal domain).
CORS_ORIGINS=https://WEB_DOMAIN

# Local storage root for originals + thumbs.
STORAGE_ROOT=/srv/cyber-gallery/storage
